{
  "name": "@auralith/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Auralith — local-first AI desktop command center",
  "author": "Auralith",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node ./scripts/run-electron-vite.cjs dev",
    "build": "electron-vite build",
    "build:installer": "pnpm build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "preview": "node ./scripts/run-electron-vite.cjs preview",
    "rebuild:native": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "@auralith/core-ai": "workspace:*",
    "@auralith/core-db": "workspace:*",
    "@auralith/core-voice": "workspace:*",
    "@auralith/core-routines": "workspace:*",
    "@auralith/core-domain": "workspace:*",
    "@auralith/core-events": "workspace:*",
    "@auralith/core-ingest": "workspace:*",
    "@auralith/core-news": "workspace:*",
    "@auralith/core-retrieval": "workspace:*",
    "@auralith/core-scheduler": "workspace:*",
    "@auralith/core-suggest": "workspace:*",
    "@auralith/core-tools": "workspace:*",
    "@auralith/core-weather": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.3.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@auralith/design-system": "workspace:*",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.auralith.app",
    "productName": "Auralith",
    "copyright": "Copyright © 2026 Auralith",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/piper",
        "to": "piper",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
