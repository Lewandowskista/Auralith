    "id": "example:auto-shell-cleanup",
    "name": "Auto Temp Folder Cleanup",
    "description": "Clean the system temp folder every Sunday night at midnight.",
    "category": "system",
    "trigger": { "type": "schedule", "cronHour": 0, "cronMinute": 0 },
    "conditions": [{ "type": "weekday.in", "days": [0] }],
    "actions": [
      {
        "toolId": "shell.run",
        "params": {
          "command": "Remove-Item -Path $env:TEMP\\* -Recurse -Force -ErrorAction SilentlyContinue"
        },
        "label": "Clean temp"
      }
    ]
  },
